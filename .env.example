# notebooklm-mcp — opcjonalne zmienne środowiskowe
# Skopiuj jako .env i odkomentuj te, które chcesz nadpisać.

# Alternatywna ścieżka katalogu storage (zamiast ~/.notebooklm/)
# Przydatne dla Docker, CI/CD, multi-user setups.
# NOTEBOOKLM_HOME=/path/to/storage/dir

# Cookies bezpośrednio jako JSON (zamiast pliku) — dla CI/CD/Docker bez przeglądarki.
# Format: pełny storage_state.json jako stringified JSON.
# NOTEBOOKLM_AUTH_JSON={"cookies":[...],"origins":[]}
